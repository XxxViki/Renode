using sysbus

mach create "stm32f103"
machine LoadPlatformDescription @platforms/cpus/stm32f103.repl
sysbus LoadELF @/home/orangepi/object/renode_portable/firmware.elf

showAnalyzer sysbus.usart2

# Start GDB server
machine StartGdbServer 3333 true
start

# Register reset macro so `machine Reset` works
macro stm32f103.reset
"""
sysbus LoadELF @/home/orangepi/object/renode_portable/firmware.elf
cpu Reset
"""
